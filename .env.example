# ===========================================
# Arena Clash 环境变量配置
# ⚠️ 复制此文件为 .env 后修改配置
# ===========================================

# PostgreSQL（本地安装）
DATABASE_URL=postgresql+asyncpg://arena_admin:change_me@localhost:5432/arena_clash

# Redis（本地安装，无密码留空即可）
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=change_me_to_64_random_chars

# 应用
APP_ENV=development
LOG_LEVEL=INFO
