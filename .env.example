# ===========================================
# Arena Clash 环境变量配置
# ⚠️ 复制此文件为 .env 后修改密码
# ===========================================

# PostgreSQL
POSTGRES_DB=arena_clash
POSTGRES_USER=arena_admin
POSTGRES_PASSWORD=change_me

# Redis
REDIS_PASSWORD=change_me

# JWT
SECRET_KEY=change_me_to_64_random_chars

# 应用
APP_ENV=development
LOG_LEVEL=INFO
